# Rename this file to .env and fill in your own values. Never commit .env.

# Which model provider to use: "gemini" (free tier, default) or "anthropic" (paid)
FLINS_PROVIDER=gemini

# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Only needed if FLINS_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Path to your actual Obsidian vault folder (leave default to use the built-in vault/ dir)
VAULT_PATH=./vault

# Email skill (Step 5+)
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com

# Weather skill
WEATHER_API_KEY=
DEFAULT_LOCATION=Bengaluru,IN
